@model CategoryEditViewModel
@{ ViewData["Title"] = "Edit Category"; }

<h1>Edit Category</h1>

<form method="post" asp-controller="Categories" asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="All" class="text-danger"></div>

    <partial name="_CategoryForm" model="Model" />

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-controller="Categories" asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}