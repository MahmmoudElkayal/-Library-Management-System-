@model BorrowApproveViewModel
@{ ViewData["Title"] = "Approve Borrow Request"; }

<h1>Approve Borrow Request</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <p><strong>Book:</strong> @Model.BookTitle</p>
                <p><strong>Member:</strong> @Model.MemberName</p>
                <p><strong>Requested:</strong> @Model.RequestedDate.ToShortDateString()</p>
            </div>
        </div>

        <form method="post" asp-controller="Borrow" asp-action="Approve">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="BookTitle" />
            <input type="hidden" asp-for="MemberName" />
            <input type="hidden" asp-for="RequestedDate" />
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="PickupDate" class="form-label"></label>
                <input asp-for="PickupDate" class="form-control" type="datetime-local" />
                <span asp-validation-for="PickupDate" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success">Approve & Set Pickup Date</button>
            <a asp-controller="Borrow" asp-action="PendingRequests" class="btn btn-secondary ms-2">Back to Requests</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}