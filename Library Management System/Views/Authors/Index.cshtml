@model IEnumerable<Author>
@{ ViewData["Title"] = "Authors"; }

<h1>Authors</h1>
<a asp-controller="Authors" asp-action="Create" class="btn btn-success mb-3">+ Add New Author</a>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Bio</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var author in Model)
        {
            <tr>
                <td>@author.Id</td>
                <td>@author.Name</td>
                <td>@author.Bio</td>
                <td>
                    <a asp-controller="Authors" asp-action="Details" asp-route-id="@author.Id" class="btn btn-primary btn-sm">Details</a>
                    <a asp-controller="Authors" asp-action="Edit" asp-route-id="@author.Id" class="btn btn-warning btn-sm">Edit</a>
                    <form method="post" asp-controller="Authors" asp-action="Delete" asp-route-id="@author.Id" style="display:inline;" onsubmit="return confirm('Are you sure?')">
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>