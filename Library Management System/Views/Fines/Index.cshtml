@model IEnumerable<Fine>
@{ ViewData["Title"] = "Fines"; }

<h1>Fines</h1>
<a asp-controller="Fines" asp-action="Create" class="btn btn-success mb-3">+ Add New Fine</a>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Member</th>
            <th>Borrow Record</th>
            <th>Amount</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var fine in Model)
        {
            <tr>
                <td>@fine.Id</td>
                <td>@fine.Member?.UserName</td>
                <td>#@fine.BorrowRecordId</td>
                <td>@fine.Amount.ToString("C")</td>
                <td>
                    @if (fine.IsPaid)
                    {
                        <span class="badge bg-success">Paid</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Unpaid</span>
                    }
                </td>
                <td>
                    @if (!fine.IsPaid)
                    {
                        <form method="post" asp-controller="Fines" asp-action="MarkPaid" asp-route-id="@fine.Id" style="display:inline;">
                            <button type="submit" class="btn btn-success btn-sm">Mark Paid</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>