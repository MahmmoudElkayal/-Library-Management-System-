@model BookCatalogViewModel
@{ 
    ViewData["Title"] = "Book Catalog";
}

<!-- Catalog Header -->
<section class="catalog-header">
    <div class="container">
        <div class="catalog-header-content">
            <h1 class="catalog-title">
                <i class="fas fa-book-open"></i> Book Catalog
            </h1>
            <p class="catalog-subtitle">Discover your next great read from our collection of @Model.TotalBooks books</p>
            
            <!-- Quick Stats -->
            <div class="catalog-stats">
                <div class="stat-item">
                    <span class="stat-number">@Model.TotalBooks</span>
                    <span class="stat-label">Total Books</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">@Model.AvailableBooks</span>
                    <span class="stat-label">Available Now</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">@Model.Categories.Count</span>
                    <span class="stat-label">Categories</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Catalog Controls -->
<section class="catalog-controls">
    <div class="container">
        <div class="controls-wrapper">
            <!-- Search Bar -->
            <div class="search-section">
                <form asp-controller="Books" asp-action="Index" method="get" class="catalog-search-form">
                    <div class="search-input-wrapper">
                        <i class="fas fa-search search-icon"></i>
                        <input type="text" 
                               name="searchString" 
                               class="catalog-search-input" 
                               placeholder="Search by title, author, ISBN, or category..."
                               value="@Model.SearchString" />
                        @if (!string.IsNullOrEmpty(Model.SearchString))
                        {
                            <a href="@Url.Action("Index", "Books")" class="clear-search" title="Clear search">
                                <i class="fas fa-times"></i>
                            </a>
                        }
                    </div>
                    <button type="submit" class="btn btn-search">
                        <i class="fas fa-search"></i> Search
                    </button>
                </form>
            </div>

            <!-- Filters & Sort -->
            <div class="filters-section">
                <form asp-controller="Books" asp-action="Index" method="get" class="filters-form" id="filtersForm">
                    <input type="hidden" name="searchString" value="@Model.SearchString" />
                    
                    <div class="filter-group">
                        <label for="categoryFilter"><i class="fas fa-folder"></i> Category</label>
                        <select name="categoryId" id="categoryFilter" class="filter-select" onchange="this.form.submit()">
                            <option value="">All Categories</option>
                            @foreach (var category in Model.Categories)
                            {
                                <option value="@category.Value" selected="@(Model.SelectedCategoryId?.ToString() == category.Value ? "selected" : null)">@category.Text</option>
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label for="authorFilter"><i class="fas fa-user-pen"></i> Author</label>
                        <select name="authorId" id="authorFilter" class="filter-select" onchange="this.form.submit()">
                            <option value="">All Authors</option>
                            @foreach (var author in Model.Authors)
                            {
                                <option value="@author.Value" selected="@(Model.SelectedAuthorId?.ToString() == author.Value ? "selected" : null)">@author.Text</option>
                            }
                        </select>
                    </div>

                    <div class="filter-group">
                        <label for="sortOrder"><i class="fas fa-sort"></i> Sort By</label>
                        <select name="sortOrder" id="sortOrder" class="filter-select" onchange="this.form.submit()">
                            <option value="" selected="@(string.IsNullOrEmpty(Model.SortOrder) ? "selected" : null)">Title (A-Z)</option>
                            <option value="title_desc" selected="@(Model.SortOrder == "title_desc" ? "selected" : null)">Title (Z-A)</option>
                            <option value="author" selected="@(Model.SortOrder == "author" ? "selected" : null)">Author (A-Z)</option>
                            <option value="author_desc" selected="@(Model.SortOrder == "author_desc" ? "selected" : null)">Author (Z-A)</option>
                            <option value="category" selected="@(Model.SortOrder == "category" ? "selected" : null)">Category</option>
                        </select>
                    </div>

                    <a href="@Url.Action("Index", "Books")" class="btn btn-reset">
                        <i class="fas fa-undo"></i> Reset
                    </a>
                </form>

                <!-- View Mode Toggle -->
                <div class="view-mode-toggle">
                    <span class="view-label">View:</span>
                    <a href="@Url.Action("Index", "Books", new { searchString = Model.SearchString, categoryId = Model.SelectedCategoryId, authorId = Model.SelectedAuthorId, sortOrder = Model.SortOrder, viewMode = "grid" })" 
                       class="view-btn @(Model.ViewMode == "grid" ? "active" : "")" title="Grid view">
                        <i class="fas fa-th-large"></i>
                    </a>
                    <a href="@Url.Action("Index", "Books", new { searchString = Model.SearchString, categoryId = Model.SelectedCategoryId, authorId = Model.SelectedAuthorId, sortOrder = Model.SortOrder, viewMode = "list" })" 
                       class="view-btn @(Model.ViewMode == "list" ? "active" : "")" title="List view">
                        <i class="fas fa-list"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Active Filters Display -->
        @if (!string.IsNullOrEmpty(Model.SearchString) || Model.SelectedCategoryId.HasValue || Model.SelectedAuthorId.HasValue)
        {
            <div class="active-filters">
                <span class="filters-label">Active filters:</span>
                @if (!string.IsNullOrEmpty(Model.SearchString))
                {
                    <span class="filter-tag">
                        <i class="fas fa-search"></i> "@Model.SearchString"
                    </span>
                }
                @if (Model.SelectedCategoryId.HasValue)
                {
                    var category = Model.Categories.FirstOrDefault(c => c.Value == Model.SelectedCategoryId.ToString());
                    <span class="filter-tag">
                        <i class="fas fa-folder"></i> @category?.Text
                    </span>
                }
                @if (Model.SelectedAuthorId.HasValue)
                {
                    var author = Model.Authors.FirstOrDefault(a => a.Value == Model.SelectedAuthorId.ToString());
                    <span class="filter-tag">
                        <i class="fas fa-user"></i> @author?.Text
                    </span>
                }
            </div>
        }
    </div>
</section>

<!-- Books Display -->
<section class="books-display">
    <div class="container">
        @if (Model.Books.Any())
        {
            <!-- Grid View -->
            @if (Model.ViewMode == "grid")
            {
                <div class="books-grid">
                    @foreach (var book in Model.Books)
                    {
                        <div class="book-grid-card" data-book-id="@book.Id">
                            <div class="book-cover-wrapper">
                                @if (!string.IsNullOrEmpty(book.CoverImage))
                                {
                                    <img src="~/images/books/@book.CoverImage" alt="@book.Title" class="book-cover" loading="lazy" />
                                }
                                else
                                {
                                    <div class="book-cover-placeholder">
                                        <i class="fas fa-book"></i>
                                        <span>No Cover</span>
                                    </div>
                                }
                                <div class="book-overlay">
                                    <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="btn btn-view">
                                        <i class="fas fa-eye"></i> View Details
                                    </a>
                                    @if (User.Identity?.IsAuthenticated == true)
                                    {
                                        <a asp-controller="Borrow" asp-action="RequestBook" asp-route-bookId="@book.Id" class="btn btn-borrow">
                                            <i class="fas fa-hand-holding-heart"></i> Borrow
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Account" asp-action="Login" class="btn btn-borrow" onclick="sessionStorage.setItem('returnUrl', '@Url.Action("RequestBook", "Borrow", new { bookId = book.Id })')">
                                            <i class="fas fa-sign-in-alt"></i> Login to Borrow
                                        </a>
                                    }
                                </div>
                                @if (book.BorrowRecords != null && book.BorrowRecords.Any(br => br.ReturnDate == null))
                                {
                                    <span class="availability-badge borrowed">
                                        <i class="fas fa-clock"></i> Borrowed
                                    </span>
                                }
                                else
                                {
                                    <span class="availability-badge available">
                                        <i class="fas fa-check-circle"></i> Available
                                    </span>
                                }
                            </div>
                            <div class="book-info">
                                <h3 class="book-title">@book.Title</h3>
                                <p class="book-author">
                                    <i class="fas fa-user-pen"></i> @book.Author?.Name
                                </p>
                                <div class="book-meta">
                                    <span class="category-badge">
                                        <i class="fas fa-tag"></i> @book.Category?.Name
                                    </span>
                                    @if (!string.IsNullOrEmpty(book.ISBN))
                                    {
                                        <span class="isbn">ISBN: @book.ISBN</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- List View -->
                <div class="books-list">
                    @foreach (var book in Model.Books)
                    {
                        <div class="book-list-item" data-book-id="@book.Id">
                            <div class="list-cover-wrapper">
                                @if (!string.IsNullOrEmpty(book.CoverImage))
                                {
                                    <img src="~/images/books/@book.CoverImage" alt="@book.Title" class="list-cover" loading="lazy" />
                                }
                                else
                                {
                                    <div class="list-cover-placeholder">
                                        <i class="fas fa-book"></i>
                                    </div>
                                }
                            </div>
                            <div class="list-book-info">
                                <h3 class="list-book-title">@book.Title</h3>
                                <p class="list-book-author">
                                    <i class="fas fa-user-pen"></i> @book.Author?.Name
                                </p>
                                <div class="list-book-meta">
                                    <span class="category-badge">
                                        <i class="fas fa-tag"></i> @book.Category?.Name
                                    </span>
                                    @if (!string.IsNullOrEmpty(book.ISBN))
                                    {
                                        <span class="isbn"><i class="fas fa-barcode"></i> @book.ISBN</span>
                                    }
                                    @if (book.BorrowRecords != null && book.BorrowRecords.Any(br => br.ReturnDate == null))
                                    {
                                        <span class="status-badge borrowed">
                                            <i class="fas fa-clock"></i> Currently Borrowed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="status-badge available">
                                            <i class="fas fa-check-circle"></i> Available
                                        </span>
                                    }
                                </div>
                            </div>
                            <div class="list-book-actions">
                                <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="btn btn-outline-primary">
                                    <i class="fas fa-eye"></i> Details
                                </a>
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <a asp-controller="Borrow" asp-action="RequestBook" asp-route-bookId="@book.Id" class="btn btn-primary">
                                        <i class="fas fa-hand-holding-heart"></i> Borrow
                                    </a>
                                }
                                else
                                {
                                    <a asp-controller="Account" asp-action="Login" class="btn btn-primary" onclick="sessionStorage.setItem('returnUrl', '@Url.Action("RequestBook", "Borrow", new { bookId = book.Id })')">
                                        <i class="fas fa-sign-in-alt"></i> Login
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav class="catalog-pagination" aria-label="Page navigation">
                    <ul class="pagination">
                        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                            <a class="page-link" href="@Url.Action("Index", "Books", new { searchString = Model.SearchString, categoryId = Model.SelectedCategoryId, authorId = Model.SelectedAuthorId, sortOrder = Model.SortOrder, viewMode = Model.ViewMode, page = Model.CurrentPage - 1 })">
                                <i class="fas fa-chevron-left"></i> Previous
                            </a>
                        </li>
                        
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", "Books", new { searchString = Model.SearchString, categoryId = Model.SelectedCategoryId, authorId = Model.SelectedAuthorId, sortOrder = Model.SortOrder, viewMode = Model.ViewMode, page = i })">@i</a>
                            </li>
                        }
                        
                        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                            <a class="page-link" href="@Url.Action("Index", "Books", new { searchString = Model.SearchString, categoryId = Model.SelectedCategoryId, authorId = Model.SelectedAuthorId, sortOrder = Model.SortOrder, viewMode = Model.ViewMode, page = Model.CurrentPage + 1 })">
                                Next <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                    <p class="pagination-info">Showing @((Model.CurrentPage - 1) * Model.PageSize + 1) - @(Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalBooks)) of @Model.TotalBooks books</p>
                </nav>
            }
        }
        else
        {
            <!-- Empty State -->
            <div class="empty-catalog">
                <div class="empty-icon">
                    <i class="fas fa-search"></i>
                </div>
                <h2>No books found</h2>
                <p>We couldn't find any books matching your criteria.</p>
                <div class="empty-suggestions">
                    <p>Try:</p>
                    <ul>
                        <li>Checking your spelling</li>
                        <li>Using more general keywords</li>
                        <li>Clearing some filters</li>
                        <li>Browsing all categories</li>
                    </ul>
                </div>
                <a href="@Url.Action("Index", "Books")" class="btn btn-primary btn-lg">
                    <i class="fas fa-book-open"></i> Browse All Books
                </a>
            </div>
        }

        <!-- Login CTA for guests -->
        @if (User.Identity?.IsAuthenticated != true)
        {
            <div class="guest-cta">
                <div class="cta-content">
                    <i class="fas fa-user-circle"></i>
                    <h3>Want to borrow books?</h3>
                    <p>Sign in to your account to request books, track your loans, and manage your reading list.</p>
                    <div class="cta-actions">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
                            <i class="fas fa-sign-in-alt"></i> Sign In
                        </a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary btn-lg">
                            <i class="fas fa-user-plus"></i> Create Account
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script>
        // Store view mode preference
        document.addEventListener('DOMContentLoaded', function() {
            // Add loading animation for images
            const images = document.querySelectorAll('.book-cover, .list-cover');
            images.forEach(img => {
                img.addEventListener('load', function() {
                    this.classList.add('loaded');
                });
            });

            // Animate cards on scroll
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('animate-in');
                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.book-grid-card, .book-list-item').forEach(card => {
                observer.observe(card);
            });
        });
    </script>
}
