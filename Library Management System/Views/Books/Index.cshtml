@model IEnumerable<Book>
@{ ViewData["Title"] = "Books"; }

<h1>Books</h1>

@if (User.IsInRole("Admin"))
{
    <a asp-controller="Books" asp-action="Create" class="btn btn-success mb-3">+ Add New Book</a>
}

<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-4">
    @foreach (var book in Model)
    {
        <div class="col">
            <div class="book-card h-100" data-book-id="@book.Id">
                <div class="book-card-image">
                    @if (!string.IsNullOrEmpty(book.CoverImage))
                    {
                        <img src="~/images/books/@book.CoverImage" alt="@book.Title" class="card-img-top">
                    }
                    else
                    {
                        <div class="no-cover">
                            <i class="fas fa-book"></i>
                            <span>No Cover</span>
                        </div>
                    }
                    <div class="book-card-overlay">
                        <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="btn btn-primary btn-sm">
                            <i class="fas fa-eye"></i> View Details
                        </a>
                    </div>
                </div>
                <div class="book-card-content">
                    <h5 class="book-card-title">@book.Title</h5>
                    <p class="book-card-author">by @book.Author?.Name</p>
                    <div class="book-card-meta">
                        <span class="badge bg-secondary">@book.Category?.Name</span>
                        <small class="text-muted d-block mt-1">ISBN: @book.ISBN</small>
                    </div>
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="book-card-actions mt-3">
                            <a asp-controller="Books" asp-action="Edit" asp-route-id="@book.Id" class="btn btn-warning btn-sm">Edit</a>
                            <form method="post" asp-controller="Books" asp-action="Delete" asp-route-id="@book.Id" class="d-inline" onsubmit="return confirm('Are you sure?')">
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>