@{ ViewData["Title"] = "Visit Our Library"; }

<section class="py-5">
    <div class="container">
        <div class="row">
            <div class="col-md-6">
                <h1><i class="fas fa-map-marker-alt text-danger"></i> Visit Our Library</h1>
                <p class="lead mt-3">We'd love to see you in person! Visit us to browse the full collection, read in our quiet spaces, or pick up your reserved books.</p>

                <div class="card mt-4">
                    <div class="card-body">
                        <h5 class="card-title"><i class="fas fa-building"></i> Library Address</h5>
                        <p class="mb-1"><i class="fas fa-map-pin me-2"></i>123 Library Street, Book City, BC 12345</p>
                        <p class="mb-1"><i class="fas fa-phone me-2"></i>(555) 123-4567</p>
                        <p class="mb-1"><i class="fas fa-envelope me-2"></i>info@library.org</p>
                    </div>
                </div>

                <div class="card mt-3">
                    <div class="card-body">
                        <h5 class="card-title"><i class="fas fa-clock"></i> Library Hours</h5>
                        <table class="table table-sm mb-0">
                            <tr><td><strong>Monday - Friday</strong></td><td>9:00 AM - 8:00 PM</td></tr>
                            <tr><td><strong>Saturday</strong></td><td>10:00 AM - 6:00 PM</td></tr>
                            <tr><td><strong>Sunday</strong></td><td>12:00 PM - 5:00 PM</td></tr>
                        </table>
                    </div>
                </div>

                <div class="card mt-3">
                    <div class="card-body">
                        <h5 class="card-title"><i class="fas fa-info-circle"></i> Services</h5>
                        <ul class="mb-0">
                            <li>Free WiFi throughout the building</li>
                            <li>Study rooms available on first-come basis</li>
                            <li>Book pickup for online reservations</li>
                            <li>Children's reading area</li>
                            <li>Printing and copying services</li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mt-3 mt-md-0">
                <div class="card shadow-sm">
                    <div class="card-body p-0">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3022.615!2d-73.985!3d40.748!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDDCsDQ0JzUzLjAiTiA3M8KwNTknMDYuMCJX!5e0!3m2!1sen!2sus!4v1"
                                width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                </div>
                <div class="text-center mt-3">
                    <a href="https://maps.google.com/?q=123+Library+Street+Book+City" target="_blank" class="btn btn-primary">
                        <i class="fas fa-directions me-1"></i> Get Directions
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>