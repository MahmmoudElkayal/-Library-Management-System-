@{ ViewData["Title"] = "Admin Dashboard"; }

<h1>Admin Dashboard</h1>

<div class="row">
    <div class="col-md-3 mb-3">
        <div class="card text-white bg-primary">
            <div class="card-body">
                <h5 class="card-title">Books</h5>
                <a asp-controller="Books" asp-action="Index" class="btn btn-light btn-sm">Manage Books</a>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-white bg-success">
            <div class="card-body">
                <h5 class="card-title">Authors</h5>
                <a asp-controller="Authors" asp-action="Index" class="btn btn-light btn-sm">Manage Authors</a>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-white bg-warning">
            <div class="card-body">
                <h5 class="card-title">Categories</h5>
                <a asp-controller="Categories" asp-action="Index" class="btn btn-light btn-sm">Manage Categories</a>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card text-white bg-info">
            <div class="card-body">
                <h5 class="card-title">Borrows</h5>
                <a asp-controller="Borrow" asp-action="Index" class="btn btn-light btn-sm">Manage Borrows</a>
            </div>
        </div>
    </div>
</div>