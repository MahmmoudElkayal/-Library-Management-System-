@model IEnumerable<Book>
@{ ViewData["Title"] = "Home"; }

<div class="text-center mb-4">
    <h1 class="display-4">Library Management System</h1>
    <p class="lead">Browse our collection of books</p>
</div>

<div class="row">
    @foreach (var book in Model)
    {
        <div class="col-md-3 mb-4">
            <div class="card h-100">
                @if (!string.IsNullOrEmpty(book.CoverImage))
                {
                    <img src="~/images/books/@book.CoverImage" class="card-img-top" alt="@book.Title" style="height:200px;object-fit:cover;" />
                }
                else
                {
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:200px;">
                        <span class="text-muted">No Image</span>
                    </div>
                }
                <div class="card-body">
                    <h5 class="card-title">@book.Title</h5>
                    <p class="card-text text-muted">@book.Author?.Name</p>
                    <span class="badge bg-info">@book.Category?.Name</span>
                </div>
                <div class="card-footer">
                    <a asp-controller="Books" asp-action="Details" asp-route-id="@book.Id" class="btn btn-primary btn-sm w-100">View Details</a>
                </div>
            </div>
        </div>
    }
</div>