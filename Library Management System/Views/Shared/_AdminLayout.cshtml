<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Library Admin</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Open+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- Admin-specific CSS -->
    <style>
        /* Admin-specific overrides */
        .admin-navbar {
            background: linear-gradient(135deg, var(--deep-teal) 0%, var(--teal-light) 100%) !important;
        }
        
        .admin-sidebar {
            background: var(--white);
            border-right: 1px solid var(--gray-200);
            box-shadow: var(--shadow-sm);
            transition: background-color var(--transition-normal);
        }
        
        .dark-mode .admin-sidebar {
            background: var(--gray-100);
            border-right-color: var(--gray-300);
        }
        
        .admin-sidebar .nav-link {
            color: var(--gray-700) !important;
            padding: var(--spacing-md) var(--spacing-lg);
            border-radius: var(--radius-md);
            margin-bottom: var(--spacing-xs);
            transition: all var(--transition-fast);
        }
        
        .admin-sidebar .nav-link:hover,
        .admin-sidebar .nav-link:focus {
            background-color: rgba(199, 91, 57, 0.1);
            color: var(--terracotta) !important;
            transform: translateX(5px);
        }
        
        .admin-sidebar .nav-link.active {
            background-color: var(--terracotta);
            color: var(--white) !important;
        }
        
        .admin-sidebar .nav-section-title {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--gray-500);
            margin: var(--spacing-xl) 0 var(--spacing-sm);
            padding-left: var(--spacing-lg);
        }
        
        .admin-content {
            background: var(--cream);
            min-height: calc(100vh - 70px);
            transition: background-color var(--transition-normal);
        }
        
        .dark-mode .admin-content {
            background: var(--gray-100);
        }
        
        .admin-footer {
            background: var(--gray-100);
            border-top: 1px solid var(--gray-200);
            transition: all var(--transition-normal);
        }
        
        .dark-mode .admin-footer {
            background: var(--gray-200);
            border-top-color: var(--gray-300);
        }
        
        /* Admin badges */
        .admin-badge {
            background: var(--terracotta);
            color: var(--white);
            padding: 2px 8px;
            border-radius: var(--radius-xl);
            font-size: 0.7rem;
            font-weight: 600;
            margin-left: var(--spacing-xs);
        }
        
        /* Admin cards */
        .admin-card {
            background: var(--white);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--gray-200);
            transition: all var(--transition-fast);
        }
        
        .admin-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
        }
        
        .dark-mode .admin-card {
            background: var(--gray-200);
            border-color: var(--gray-300);
        }
    </style>
</head>
<body class="light-mode">
    <!-- Admin Header -->
    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-dark admin-navbar">
            <div class="container-fluid">
                <!-- Logo -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Dashboard">
                    <span class="logo-icon">📚</span>
                    <span class="logo-text">Library Admin</span>
                </a>
                
                <!-- Mobile toggle -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <!-- Navigation -->
                <div class="collapse navbar-collapse" id="adminNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Dashboard">
                                <i class="fas fa-tachometer-alt"></i> Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Books" asp-action="Index">
                                <i class="fas fa-book"></i> Books
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Authors" asp-action="Index">
                                <i class="fas fa-user-pen"></i> Authors
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Categories" asp-action="Index">
                                <i class="fas fa-folder"></i> Categories
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Borrow" asp-action="Index">
                                <i class="fas fa-exchange-alt"></i> Borrows
                                <span class="admin-badge">5</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Borrow" asp-action="PendingRequests">
                                <i class="fas fa-clock"></i> Pending
                                <span class="admin-badge">3</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Fines" asp-action="Index">
                                <i class="fas fa-dollar-sign"></i> Fines
                            </a>
                        </li>
                    </ul>
                    
                    <!-- Right side actions -->
                    <div class="d-flex align-items-center gap-3">
                        <!-- Dark mode toggle -->
                        <button type="button" class="btn btn-theme-toggle" id="themeToggle" title="Toggle dark/light mode">
                            <i class="fas fa-moon"></i>
                        </button>
                        
                        <!-- Login partial -->
                        <ul class="navbar-nav">
                            @await Html.PartialAsync("_LoginPartial")
                        </ul>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content Area -->
    <div class="container-fluid mt-3">
        <div class="row">
            <!-- Admin Sidebar -->
            <div class="col-md-2 d-none d-md-block admin-sidebar py-3" style="min-height: calc(100vh - 70px);">
                <div class="d-flex flex-column">
                    <!-- Section: Books -->
                    <div class="nav-section-title">📚 Books Management</div>
                    <a class="nav-link" asp-controller="Books" asp-action="Index">
                        <i class="fas fa-list"></i> All Books
                    </a>
                    <a class="nav-link" asp-controller="Books" asp-action="Create">
                        <i class="fas fa-plus"></i> Add New Book
                    </a>
                    
                    <!-- Section: Authors & Categories -->
                    <div class="nav-section-title">👥 People & Categories</div>
                    <a class="nav-link" asp-controller="Authors" asp-action="Index">
                        <i class="fas fa-user-pen"></i> Manage Authors
                    </a>
                    <a class="nav-link" asp-controller="Categories" asp-action="Index">
                        <i class="fas fa-folder"></i> Manage Categories
                    </a>
                    
                    <!-- Section: Borrows -->
                    <div class="nav-section-title">📋 Borrowing System</div>
                    <a class="nav-link" asp-controller="Borrow" asp-action="Index">
                        <i class="fas fa-exchange-alt"></i> All Borrows
                    </a>
                    <a class="nav-link" asp-controller="Borrow" asp-action="Create">
                        <i class="fas fa-plus"></i> Direct Borrow
                    </a>
                    <a class="nav-link" asp-controller="Borrow" asp-action="PendingRequests">
                        <i class="fas fa-clock"></i> Pending Requests
                        <span class="admin-badge">3</span>
                    </a>
                    
                    <!-- Section: Fines -->
                    <div class="nav-section-title">💰 Financial</div>
                    <a class="nav-link" asp-controller="Fines" asp-action="Index">
                        <i class="fas fa-dollar-sign"></i> Manage Fines
                    </a>
                    
                    <!-- Section: System -->
                    <div class="nav-section-title">⚙️ System</div>
                    <a class="nav-link" asp-controller="Home" asp-action="Dashboard">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                    <a class="nav-link" href="#">
                        <i class="fas fa-cog"></i> Settings
                    </a>
                </div>
            </div>
            
            <!-- Main Content -->
            <div class="col-md-10 admin-content">
                <!-- Alerts -->
                <div class="container-fluid py-3">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                </div>
                
                <!-- Page Content -->
                <div class="container-fluid px-4">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <!-- Admin Footer -->
    <footer class="admin-footer mt-5 py-3">
        <div class="container-fluid text-center">
            <div class="row align-items-center">
                <div class="col-md-6 text-md-start">
                    <small class="text-muted">
                        &copy; 2026 - Library Management System (Admin Panel)
                    </small>
                </div>
                <div class="col-md-6 text-md-end">
                    <small class="text-muted">
                        <i class="fas fa-shield-alt me-1"></i> Secure Admin Access
                        <span class="mx-2">|</span>
                        <i class="fas fa-chart-line me-1"></i> System Status: <span class="text-success">Online</span>
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Custom JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <!-- Admin-specific JS -->
    <script>
        // Admin-specific initialization
        document.addEventListener('DOMContentLoaded', function() {
            // Highlight active sidebar link
            const currentPath = window.location.pathname;
            const sidebarLinks = document.querySelectorAll('.admin-sidebar .nav-link');
            
            sidebarLinks.forEach(link => {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                }
            });
            
            // Tooltips for admin badges
            const adminBadges = document.querySelectorAll('.admin-badge');
            adminBadges.forEach(badge => {
                badge.setAttribute('title', 'Click to view details');
                badge.style.cursor = 'pointer';
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>