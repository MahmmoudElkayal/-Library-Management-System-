<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Library Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #2c3e50;">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <span class="text-white">📚 Library Admin</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="adminNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Home" asp-action="Dashboard">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Books" asp-action="Index">Books</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Authors" asp-action="Index">Authors</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Categories" asp-action="Index">Categories</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Borrow" asp-action="Index">Borrows</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Borrow" asp-action="PendingRequests">Pending Requests</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Fines" asp-action="Index">Fines</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    @await Html.PartialAsync("_LoginPartial")
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid mt-3">
        <div class="row">
            <div class="col-md-2 d-none d-md-block bg-light sidebar py-3" style="min-height: calc(100vh - 70px);">
                <nav class="nav flex-column">
                    <a class="nav-link text-dark fw-semibold" asp-controller="Books" asp-action="Index">📖 Books</a>
                    <a class="nav-link text-dark" asp-controller="Books" asp-action="Create">+ Add Book</a>
                    <hr />
                    <a class="nav-link text-dark fw-semibold" asp-controller="Authors" asp-action="Index">✍ Authors</a>
                    <a class="nav-link text-dark fw-semibold" asp-controller="Categories" asp-action="Index">📂 Categories</a>
                    <hr />
                    <a class="nav-link text-dark fw-semibold" asp-controller="Borrow" asp-action="Index">📋 Borrows</a>
                    <a class="nav-link text-dark" asp-controller="Borrow" asp-action="Create">+ Direct Borrow</a>
                    <a class="nav-link text-dark" asp-controller="Borrow" asp-action="PendingRequests">⏳ Pending Requests</a>
                    <hr />
                    <a class="nav-link text-dark fw-semibold" asp-controller="Fines" asp-action="Index">💲 Fines</a>
                </nav>
            </div>
            <div class="col-md-10">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </div>
        </div>
    </div>

    <footer class="border-top footer text-muted mt-5 py-3">
        <div class="container text-center">
            &copy; 2026 - Library Management System (Admin)
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>