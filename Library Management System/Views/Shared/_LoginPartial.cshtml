@using Microsoft.AspNetCore.Identity
@using LibraryManagementSystem.Models
@inject SignInManager<LibraryMember> SignInManager
@inject UserManager<LibraryMember> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link" asp-controller="Member" asp-action="Profile">Hello, @User.Identity?.Name</a>
    </li>
    <li class="nav-item">
        <form method="post" asp-controller="Account" asp-action="Logout">
            <button type="submit" class="nav-link btn btn-link text-light" style="border:none;padding:0;">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-controller="Account" asp-action="Register">Register</a>
    </li>
    <li class="nav-item">
        <a class="nav-link" asp-controller="Account" asp-action="Login">Login</a>
    </li>
}