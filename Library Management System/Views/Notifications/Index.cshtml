@model IEnumerable<Notification>
@{ ViewData["Title"] = "Notifications"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1><i class="fas fa-bell"></i> Notifications</h1>
    @if (Model.Any(n => !n.IsRead))
    {
        <form method="post" asp-controller="Notifications" asp-action="MarkAllAsRead">
            <button type="submit" class="btn btn-outline-primary btn-sm">
                <i class="fas fa-check-double"></i> Mark All as Read
            </button>
        </form>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> You have no notifications.
    </div>
}
else
{
    <div class="list-group">
        @foreach (var notification in Model)
        {
            <div class="list-group-item list-group-item-action @(notification.IsRead ? "" : "list-group-item-primary")">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        @switch (notification.Type)
                        {
                            case "Approval":
                                <i class="fas fa-check-circle text-success me-2"></i>
                                break;
                            case "Rejection":
                                <i class="fas fa-times-circle text-danger me-2"></i>
                                break;
                            case "Overdue":
                                <i class="fas fa-exclamation-triangle text-warning me-2"></i>
                                break;
                            default:
                                <i class="fas fa-info-circle text-info me-2"></i>
                                break;
                        }
                        <span class="@(notification.IsRead ? "text-muted" : "fw-bold")">@notification.Message</span>
                    </div>
                    <div class="text-end">
                        <small class="text-muted">@notification.CreatedAt.ToShortDateString() @notification.CreatedAt.ToShortTimeString()</small>
                        @if (!notification.IsRead)
                        {
                            <form method="post" asp-controller="Notifications" asp-action="MarkAsRead" asp-route-id="@notification.Id" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-secondary ms-2">
                                    <i class="fas fa-check"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}